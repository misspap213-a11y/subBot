# ── Subscription Bot ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# On Railway, set these in the Variables tab instead.

# Telegram bot token from @BotFather (required)
SUB_BOT_TOKEN=

# Shared secret used to authenticate POST /broadcast requests.
# Set the same value in the Futures bot's .env as SUB_BOT_API_KEY.
SUB_BOT_API_KEY=change_me_to_a_random_secret

# HTTP server — Railway sets PORT automatically, you don't need to change this
SUB_BOT_HOST=0.0.0.0
# SUB_BOT_PORT=8080   ← ignored on Railway (PORT is injected automatically)

# Telegram chat_id of the bot owner — receives payment notifications
# and can run /approve, /deny, /pending, /stats
ADMIN_CHAT_ID=

# SQLite database path
# NOTE: Railway's filesystem is ephemeral. Mount a Volume at /data and set:
# DB_PATH=/data/subscribers.db
DB_PATH=subscribers.db

# ── Subscription settings ─────────────────────────────────────────────────────

# FREE_ACCESS=true  → anyone can /start and receive signals for free
# FREE_ACCESS=false → signals are only sent to users with an active paid sub
FREE_ACCESS=false

# Telegram Stars price per period (50 Stars ≈ $1 USD)
SUB_PRICE_STARS=100

# Subscription duration in days (applies to all payment methods)
SUB_DURATION_DAYS=30

# Display name shown in welcome messages
CHANNEL_NAME=Futures Signals

# ── Crypto payment wallets ────────────────────────────────────────────────────
# Leave a wallet blank to hide that coin from the payment menu.

# USD price shown to users for crypto payments
CRYPTO_PRICE_USD=5

CRYPTO_BTC_ADDRESS=
CRYPTO_ETH_ADDRESS=
CRYPTO_USDT_ADDRESS=
CRYPTO_SOL_ADDRESS=
